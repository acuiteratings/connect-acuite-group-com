{
  "name": "acuite-connect",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "backend:dev": "cd backend && ../.venv/bin/python manage.py runserver 127.0.0.1:8240",
    "backend:collectstatic": "cd backend && ../.venv/bin/python manage.py collectstatic --noinput",
    "backend:check": "cd backend && ../.venv/bin/python manage.py check",
    "backend:migrate": "cd backend && ../.venv/bin/python manage.py migrate",
    "backend:seed": "cd backend && ../.venv/bin/python manage.py seed_connect_demo",
    "backend:test": "cd backend && ../.venv/bin/python manage.py test"
  }
}
