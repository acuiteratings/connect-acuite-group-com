DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_TIME_ZONE=Asia/Kolkata
DJANGO_CSRF_TRUSTED_ORIGINS=
DATABASE_URL=
RENDER_EXTERNAL_HOSTNAME=
USE_X_FORWARDED_HOST=false
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=false

DATABASE_ENGINE=sqlite
POSTGRES_DB=acuite_connect
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
APP_BUILD_NUMBER=1.0000001
APP_BUILD_CREDIT=Created with care by Sankar Chakraborti

AUTH_PASSWORD_MAX_AGE_DAYS=90
AUTH_OTP_TTL_MINUTES=10
AUTH_OTP_CODE_LENGTH=6
AUTH_OTP_RESEND_COOLDOWN_SECONDS=60
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_PASSWORD_MAX_ATTEMPTS=5
AUTH_DEBUG_OTP_PREVIEW=true

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_TIMEOUT=15
DEFAULT_FROM_EMAIL=connect@acuite-group.com
SERVER_EMAIL=connect@acuite-group.com
